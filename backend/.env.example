# Server
NODE_ENV=development
SERVER_PORT=5000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/thabat?schema=public

# JWT (configure before enabling authentication)
JWT_SECRET=change-me-in-production
JWT_EXPIRES=15m
REFRESH_SECRET=change-me-in-production

# Email (Nodemailer)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# Client
CLIENT_URL=http://localhost:5173

# Logging
LOG_LEVEL=info

# Seed admin (required in production, optional in dev - see seed.js)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
